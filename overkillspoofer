local function profileWeaponRows()
    local root = pg()
    local weapons = root and byPath(root, {"Lobby", "PlayerProfile", "Main", "Weapons"})
    local rows = {}
    if not weapons then return rows end

    for _, row in ipairs(weapons:GetChildren()) do
        if row:IsA("GuiObject") and row.Visible and row.Name ~= "Template" then
            local main = row:FindFirstChild("Main")
            if main then
                local hasName = main:FindFirstChild("ItemName") or main:FindFirstChild("ItemCount")
                local hasRender = main:FindFirstChild("Holder") and main.Holder:FindFirstChild("WeaponTemplate") and main.Holder.WeaponTemplate:FindFirstChild("Render")
                local hasIcon = main:FindFirstChild("Icon")
                if hasName or hasRender or hasIcon then
                    table.insert(rows, row)
                end
            end
        end
    end

    table.sort(rows, function(a, b)
        local ay = math.floor(a.AbsolutePosition.Y / 8)
        local by = math.floor(b.AbsolutePosition.Y / 8)
        if ay == by then
            return a.AbsolutePosition.X < b.AbsolutePosition.X
        end
        return a.AbsolutePosition.Y < b.AbsolutePosition.Y
    end)

    return rows
end

local function setProfileWeaponRow(row, weaponName, image)
