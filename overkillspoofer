                pcall(function() button.AutoButtonColor = true end)

                for _, obj in ipairs(button:GetDescendants()) do
                    if isText(obj) then
                        local low = obj.Text:lower()
                        if row.Name == selected and selected ~= "" then setText(obj, "Equipped")
                        elseif low:find("locked") or low == "" then setText(obj, "Equip") end
                    end
                end

                if button:IsA("GuiButton") and not button:GetAttribute("OverkillTitleHooked") then
                    button:SetAttribute("OverkillTitleHooked", true)
                    button.MouseButton1Click:Connect(function() equipTitle(row.Name, titleText) end)
                    button.Activated:Connect(function() equipTitle(row.Name, titleText) end)
                end
            end

            for _, obj in ipairs(row:GetDescendants()) do
                if isText(obj) and obj.Text:lower():find("locked") then setText(obj, "Equip") end
            end
        end
    end

    spoofTitleVisual()
end

