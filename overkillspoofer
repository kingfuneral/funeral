local function applyPerformance()
    if not PerfEnabled then return end
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    if LowLighting then
        pcall(function()
            Lighting.GlobalShadows = false
            Lighting.FogEnd = 100000
            Lighting.Brightness = 1
        end)
        for _, obj in ipairs(Lighting:GetChildren()) do
            if obj:IsA("BloomEffect") or obj:IsA("SunRaysEffect") or obj:IsA("DepthOfFieldEffect") or obj:IsA("BlurEffect") then pcall(function() obj.Enabled = false end) end
        end
    end
    if DisableParticles then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then pcall(function() obj.Enabled = false end) end
        end
    end
    pcall(function() Workspace.Terrain.Decoration = false end)
end

