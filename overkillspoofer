local function byPath(root, path)
    local cur = root
    for _, name in ipairs(path) do
        if not cur then return nil end
        cur = cur:FindFirstChild(name)
    end
    return cur
end

local function isText(obj)
    return obj and (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox"))
end

local function cleanNumber(value)
    return tostring(value or ""):gsub(",", ""):match("%-?%d+%.?%d*") or ""
end

local function commaNumber(value)
    local s = cleanNumber(value)
    if s == "" then return "" end
    local sign, int, dec = s:match("^([%-]?)(%d+)(%.?%d*)$")
    if not int then return s end
    return sign .. int:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "") .. (dec or "")
end

local function normalize(name, value)
    local s = tostring(value or "")
    if s == "" then return "" end
    if name == "Level" then return "Lvl. " .. commaNumber(s) end
    if name == "RawLevel" then return commaNumber(s) end
    if name == "Wins" or name == "Streak" then return commaNumber(s) end
    if name == "WinRate" then return cleanNumber(s:gsub("%%", "")) .. "%" end
    if name == "Username" then return "@" .. s:gsub("^@", "") end
    if name == "KDR" then return cleanNumber(s) end
    return s
end

local function setText(obj, value)
    if not isText(obj) or value == nil or value == "" then return end
    pcall(function()
        obj.Text = tostring(value)
    end)
end

local function textOf(obj)
    return isText(obj) and tostring(obj.Text) or ""
end

local function numberFrom(text)
    local n = tostring(text or ""):gsub(",", ""):match("%-?%d+")
    return tonumber(n) or 0
end

local function visual(key)
    local v = getgenv().__OverkillVisualSpoof or {}
    return v[key] and tostring(v[key]) or ""
end

local function option(id)
    local o = Options and Options[id]
    return o and tostring(o.Value or "") or ""
end

local function imageId(value)
    local s = tostring(value or "")
    if s == "" then return "" end
    local low = s:lower()
    if low == "auto" or low == "auto / asset id" or low == "asset id" or low == "none" then return "" end
    if s:find("rbxassetid://") or s:find("rbxasset://") then return s end
    local n = s:match("%d+")
    return n and ("rbxassetid://" .. n) or ""
end

local function softVisible(obj)
    if not obj then return end
    pcall(function()
        if obj:IsA("GuiObject") then obj.Visible = true end
        if obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then obj.Enabled = true end
    end)
end

local function overheadVisible(obj)
    local cur = obj
    while cur do
        softVisible(cur)
        if cur:IsA("ScreenGui") or cur:IsA("PlayerGui") then break end
        cur = cur.Parent
    end
end

local function saveWeaponAsset(name, asset)
    name = tostring(name or "")
    asset = imageId(asset)
    if name ~= "" and asset ~= "" and asset ~= "rbxasset://textures/ui/GuiImagePlaceholder.png" then
        WeaponAssets[name:lower()] = asset
        WeaponAssets[name] = asset
    end
end

local function weaponCategoryFromText(text)
    local s = tostring(text or ""):lower()
    if s:find("primary") then return "Primary" end
    if s:find("second") or s:find("secondary") then return "Second" end
    if s:find("melee") then return "Melee" end
    if s:find("utility") then return "Utility" end
    return nil
end

local function addWeaponToCatalog(category, name, image)
    category = weaponCategoryFromText(category) or category
    name = tostring(name or "")
    image = imageId(image)
    if not WeaponCatalog[category] or name == "" or image == "" then return end
    if name:lower() == "gunname" or name:lower():find("slot") then return end
    WeaponCatalog[category][name] = image
    saveWeaponAsset(name, image)
end

local function weaponImageFromName(name)
    local s = tostring(name or "")
    if s == "" then return "" end
    local direct = WeaponAssets[s] or WeaponAssets[s:lower()]
    if direct then return direct end
    local compact = s:lower():gsub("^%s+", ""):gsub("%s+$", ""):gsub("%s+", ""):gsub("%-", ""):gsub("_", "")
    if #compact < 2 then return "" end
    for weaponName, asset in pairs(WeaponAssets) do
        local key = tostring(weaponName):lower():gsub("%s+", ""):gsub("%-", ""):gsub("_", "")
        if key == compact then return asset end
    end
    for weaponName, asset in pairs(WeaponAssets) do
        local key = tostring(weaponName):lower():gsub("%s+", ""):gsub("%-", ""):gsub("_", "")
        if #compact >= 3 and (key:find(compact, 1, true) or compact:find(key, 1, true)) then return asset end
    end
    return ""
end

