local function setRowImage(row)
    if not row or Headshot == "" then return end
    for _, obj in ipairs(row:GetDescendants()) do
        if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
            local full = obj:GetFullName():lower()
            local name = obj.Name:lower()
            if not full:find("icon") and not name:find("icon") and not full:find("rank") and not full:find("value") then
                pcall(function() obj.Image = Headshot end)
            end
        end
    end
end

local function getRowValue(row)
    local icon = row and row:FindFirstChild("Icon")
    local value = icon and icon:FindFirstChild("Value")
    return numberFrom(textOf(value))
end

local function getRows(group)
    local rows = {}
    local main = group and group:FindFirstChild("Main")
    local scrolling = main and main:FindFirstChild("ScrollingFrame")
    if not scrolling then return rows, nil end
    for _, child in ipairs(scrolling:GetChildren()) do
        if child:IsA("GuiObject") and child:FindFirstChild("Username") and child:FindFirstChild("Icon") and child.Name ~= "__OverkillSpoofRow" then table.insert(rows, child) end
    end
    table.sort(rows, function(a, b) return getRowValue(a) > getRowValue(b) end)
    return rows, scrolling
end

local function writeSpoofRow(row, value, rank)
    if not row then return end
    local username = visual("LBUsername") ~= "" and normalize("Username", visual("LBUsername")) or ("@" .. LocalPlayer.Name)
    local display = visual("LBDisplay") ~= "" and visual("LBDisplay") or LocalPlayer.DisplayName
    local forcedRank = visual("LBRank")
    row.Visible = true
    setText(row:FindFirstChild("Username"), username)
    setText(row:FindFirstChild("DisplayName"), display)
    setText(row:FindFirstChild("Rank"), forcedRank ~= "" and forcedRank or ("#" .. tostring(rank)))
    local icon = row:FindFirstChild("Icon")
    if icon then setText(icon:FindFirstChild("Value"), commaNumber(value)) end
    setRowImage(row)
end

local function spoofLeaderboardGroup(group, value)
    if not group or not value or value == "" then return end
    local rows, scrolling = getRows(group)
    if not scrolling or #rows == 0 then return end

    local fake = scrolling:FindFirstChild("__OverkillSpoofRow")
    if not fake then
        fake = rows[1]:Clone()
        fake.Name = "__OverkillSpoofRow"
        fake.Parent = scrolling
    end

    local spoofNumber = numberFrom(value)
    local rank = 1
    for _, row in ipairs(rows) do if getRowValue(row) >= spoofNumber then rank += 1 end end
    rank = math.clamp(rank, 1, #rows + 1)

    for i, row in ipairs(rows) do
        row.Visible = true
        row.LayoutOrder = i >= rank and i + 1 or i
    end

    fake.LayoutOrder = rank
    writeSpoofRow(fake, value, rank)
    if #rows > 0 then rows[#rows].Visible = false end

    local main = group:FindFirstChild("Main")
    local player = main and main:FindFirstChild("Player")
    if player then writeSpoofRow(player, value, rank) end
end

local function spoofOwnWinsTables(value)
    local root = pg()
    if not root or value == "" then return end
    local shown = commaNumber(value)
    local names = {LocalPlayer.Name:lower(), LocalPlayer.DisplayName:lower(), visual("LBUsername"):lower(), visual("LBDisplay"):lower(), normalize("Username", visual("LBUsername")):lower()}

    for _, container in ipairs(root:GetDescendants()) do
        if container:IsA("GuiObject") then
            local full = container:GetFullName():lower()
            if full:find("duel") or full:find("match") or full:find("active") then
                local ownRow = false

                for _, obj in ipairs(container:GetDescendants()) do
                    if isText(obj) then
                        local txt = tostring(obj.Text or ""):lower()
                        for _, name in ipairs(names) do
                            if name ~= "" and txt == name then ownRow = true break end
                        end
                    end
                    if ownRow then break end
                end

                if ownRow then
                    for _, obj in ipairs(container:GetDescendants()) do
                        if isText(obj) then
                            local fullObj = obj:GetFullName():lower()
                            local name = obj.Name:lower()
                            if name:find("win") or fullObj:find("wins") or fullObj:find(".win") then setText(obj, shown) end
                        end
                    end
                end
            end
        end
    end
end

function applyVisual()
    local root = pg()
    if not root then return end

    local levelRaw = effectiveLevel()
    local winsRaw = effectiveWins()
    local streakRaw = effectiveStreak()
    local levelText = levelRaw ~= "" and normalize("Level", levelRaw) or ""
    local levelNumber = levelRaw ~= "" and normalize("RawLevel", levelRaw) or ""

    setPath({"Lobby", "HUD", "Top", "Currency", "Template", "Value"}, commaNumber(visual("Crowns")))
    setPath({"Lobby", "Shop", "Main", "CurrencyContainer", "Crowns", "Value"}, commaNumber(visual("Crowns")))
    setPath({"Lobby", "HUD", "PlayerLevel", "Level"}, levelText)
    setPath({"Lobby", "HUD", "PlayerLevel", "XP"}, visual("LobbyXP"))
    setPath({"Lobby", "HUD", "Right", "Leaderboard", "PlayerPopOut", "Main", "CurrentLevel"}, levelText)
    setPath({"Lobby", "HUD", "Right", "Leaderboard", "PlayerPopOut", "Main", "Username"}, normalize("Username", visual("LBUsername")))
    setPath({"Lobby", "HUD", "Right", "Leaderboard", "PlayerPopOut", "Main", "DisplayName"}, visual("LBDisplay"))
    setPath({"Lobby", "HUD", "Right", "Leaderboard", "PlayerPopOut", "Main", "Streak", "Value"}, commaNumber(streakRaw))
    setPath({"Lobby", "HUD", "Right", "Leaderboard", "PlayerPopOut", "Stats", "Wins", "Frame", "Value"}, commaNumber(winsRaw))

    setMatching(root, function(_, full, name) return full:find("currency") and name == "value" and not full:find("price") end, commaNumber(visual("Crowns")))
    setMatching(root, function(_, full) return full:find("playerlevel") and full:find("level") end, levelText)
    setMatching(root, function(_, full) return full:find("overhead") and full:find("streak") end, commaNumber(streakRaw))
    setMatching(Workspace, function(_, full) return full:find("overhead") and full:find("streak") end, commaNumber(streakRaw))
    setMatching(root, function(_, full) return full:find("overhead") and full:find("level") end, levelNumber)
    setMatching(Workspace, function(_, full) return full:find("overhead") and full:find("level") end, levelNumber)

    applyTitleUnlocker()
    spoofTitleVisual()
    applyWeaponStats()
    applyDeviceSpoof()
    spoofOwnWinsTables(winsRaw)

    local lb = byPath(root, {"SurfaceGUIs", "Screens", "Leaderboard", "Main"})
    if lb then
        spoofLeaderboardGroup(lb:FindFirstChild("Win"), winsRaw)
        spoofLeaderboardGroup(lb:FindFirstChild("WinStreak"), streakRaw)
        spoofLeaderboardGroup(lb:FindFirstChild("Level"), levelNumber)
    end
end

