    if not main then return end

    local nameLabel = main:FindFirstChild("ItemName") or main:FindFirstChild("ItemCount")
    setText(nameLabel, weaponName)

    local render = main:FindFirstChild("Holder")
        and main.Holder:FindFirstChild("WeaponTemplate")
        and main.Holder.WeaponTemplate:FindFirstChild("Render")

    if not render then
        render = main:FindFirstChild("Icon")
    end

    if image ~= "" and render and (render:IsA("ImageLabel") or render:IsA("ImageButton")) then
        pcall(function()
            render.Image = image
            render.Visible = true
        end)
    end
end

local function scrapeWeaponAssets()
    clearTable(WeaponAssets)
    for category in pairs(WeaponCatalog) do
        clearTable(WeaponCatalog[category])
    end

    local function scanCard(card)
        local weaponName = ""
        local category = ""
        local image = ""

        for _, obj in ipairs(card:GetDescendants()) do
            if isText(obj) then
                local n = obj.Name:lower()
                local txt = tostring(obj.Text or "")
                if n == "weaponname" or n == "itemname" or n == "name" or n == "title" then
                    local low = txt:lower()
                    if txt ~= "" and low ~= "gunname" and low ~= "primary" and low ~= "second" and low ~= "secondary" and low ~= "melee" and low ~= "utility" and not low:find("slot") and not low:find("selecting") then
                        weaponName = txt
                    end
                elseif n == "weaponkind" or n == "weaponclass" or n == "slottype" or n == "type" then
                    category = weaponCategoryFromText(txt) or category
                end
            elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
                local full = obj:GetFullName():lower()
                local n = obj.Name:lower()
                local img = tostring(obj.Image or "")
                if img ~= "" and img ~= "rbxasset://textures/ui/GuiImagePlaceholder.png" then
                    if n == "render" or full:find("holder%.weapontemplate%.render") or full:find("weapontemplate%.render") or n == "icon" then
                        image = img
                    end
                end
            end
        end

        local full = card:GetFullName():lower()
        if category == "" then
            if full:find("primary") then category = "Primary" end
            if full:find("second") or full:find("secondary") then category = "Second" end
            if full:find("melee") then category = "Melee" end
            if full:find("utility") then category = "Utility" end
        end

        if weaponName ~= "" and image ~= "" then
            if category ~= "" and WeaponCatalog[category] then
                addWeaponToCatalog(category, weaponName, image)
            else
                saveWeaponAsset(weaponName, image)
            end
        end
    end

    local function scanGui(base)
        if not base then return end
        for _, obj in ipairs(base:GetDescendants()) do
            local full = obj:GetFullName():lower()
            if obj:IsA("Frame") or obj:IsA("ImageButton") or obj:IsA("ImageLabel") then
                if full:find("weaponselection") or full:find("armory") or full:find("loadout") or full:find("mobile%.mobile%.slot") or full:find("bottomright%.slots%.weaponslot") or full:find("activeweapon") or full:find("playerprofile%.main%.weapons") then
                    scanCard(obj)
                end
            end
        end
    end

    local function scanDirectory()
        local milk = ReplicatedStorage:FindFirstChild("Milk")
        local dir = milk and milk:FindFirstChild("Directory")
        local weapons = dir and dir:FindFirstChild("Weapons")
        if not weapons then return end

        for _, module in ipairs(weapons:GetDescendants()) do
            if module:IsA("ModuleScript") then
                pcall(function()
                    local data = require(module)
                    if type(data) ~= "table" then return end
                    local name = data.name or data.Name or data.displayName or data.DisplayName or data.ID or data.id or module.Name
                    local category = data.weaponType or data.WeaponType or data.type or data.Type or data.slot or data.Slot or data.class or data.Class
                    local asset = data.icon or data.Icon or data.image or data.Image or data.render or data.Render or data.texture or data.Texture
                    if type(asset) == "table" then asset = asset.icon or asset.Icon or asset.image or asset.Image or asset.render or asset.Render end
                    if category then addWeaponToCatalog(category, name, asset) else saveWeaponAsset(name, asset) end
                end)
            end
        end
    end

    scanGui(pg())
    scanGui(ReplicatedStorage)
    scanDirectory()

    addWeaponToCatalog("Primary", "AK-47", "rbxassetid://89067467254686")
    addWeaponToCatalog("Primary", "Tec-9", "rbxassetid://72597371963188")
    addWeaponToCatalog("Second", "Handgun", "rbxassetid://121230308356682")
    addWeaponToCatalog("Melee", "Fist", "rbxassetid://100898054759206")
    addWeaponToCatalog("Utility", "Grenade", "rbxassetid://118255204634633")
    addWeaponToCatalog("Utility", "Satchel", "rbxassetid://75744818177901")
    addWeaponToCatalog("Utility", "Taser", "rbxassetid://81315411107481")
    addWeaponToCatalog("Utility", "Jump Pad", "rbxassetid://85428042381229")
    addWeaponToCatalog("Utility", "Medkit", "rbxassetid://134206072787096")

    WeaponScraped = true
    return WeaponAssets
end

