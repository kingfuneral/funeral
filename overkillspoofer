local function setMatching(root, fn, value)
    if not root or value == nil or value == "" then return end
    for _, obj in ipairs(root:GetDescendants()) do
        if isText(obj) then
            local ok = false
            pcall(function()
                ok = fn(obj, obj:GetFullName():lower(), obj.Name:lower(), tostring(obj.Text):lower())
            end)
            if ok then setText(obj, value) end
        end
    end
end

